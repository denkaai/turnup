# ============================================
# TURNUP - Environment Variables
# ============================================
# Copy this file to .env.local for local dev
# Add these in Netlify → Site Settings → Environment Variables for production

# ---- SUPABASE (Frontend) ----
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ---- SUPABASE (Backend / Netlify Functions) ----
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- M-PESA DARAJA API ----
# Get these from: developer.safaricom.co.ke
# Use sandbox credentials for testing, live for production
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-daraja-passkey
MPESA_CALLBACK_URL=https://your-site.netlify.app/api/mpesa-callback

# ---- NOTES ----
# For M-Pesa sandbox testing use shortcode 174379
# Switch sandbox URLs to live when going to production:
#   Sandbox: sandbox.safaricom.co.ke
#   Live:    api.safaricom.co.ke
